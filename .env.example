# ─────────────────────────────────────────────────────────────
# Apoio Vivo — variáveis de ambiente
# Copie para .env.local e preencha. O app funciona em modo LOCAL sem elas.
# ─────────────────────────────────────────────────────────────

# Supabase (autenticação + banco) — crie um projeto em https://supabase.com
# Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Settings > API > service_role (SECRETO — só usado no servidor)
SUPABASE_SERVICE_ROLE_KEY=

# Resend (envio de e-mail de alerta) — https://resend.com/api-keys
RESEND_API_KEY=
# Remetente. Para teste sem domínio próprio use: Apoio Vivo <onboarding@resend.dev>
ALERTA_EMAIL_FROM=Apoio Vivo <onboarding@resend.dev>
